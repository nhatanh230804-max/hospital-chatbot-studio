# =============================================================================
# .env.production - Template cho deploy nội bộ
# =============================================================================
# HƯỚNG DẪN:
# 1. Đổi tên file này thành `.env` khi deploy
# 2. Thay thế MỌI giá trị có dấu <...> bằng giá trị thật
# 3. Generate password mạnh bằng PowerShell:
#      -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | % {[char]$_})
#    Hoặc bash:
#      openssl rand -base64 32
# =============================================================================

PORT=8080

# -----------------------------------------------------------------------------
# MySQL connection (cho DB chính `hospital_demo` của chatbot)
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=hospital_user
DB_PASSWORD=<DOI_PASSWORD_MANH_O_DAY>
DB_NAME=hospital_demo

# -----------------------------------------------------------------------------
# AnythingLLM (AI backend)
# Nếu deploy chung server với chatbot:
#   ANYTHINGLLM_BASE_URL=http://localhost:3001
# Nếu deploy AnythingLLM ở server khác trong LAN:
#   ANYTHINGLLM_BASE_URL=http://192.168.1.51:3001
# -----------------------------------------------------------------------------
ANYTHINGLLM_BASE_URL=http://localhost:3001
ANYTHINGLLM_API_KEY=<GENERATE_TREN_ANYTHINGLLM_WEB>
ANYTHINGLLM_WORKSPACE_SLUG=test-chatbot-bv
ANYTHINGLLM_MODE=chat

# -----------------------------------------------------------------------------
# Admin token - BẮT BUỘC đổi sang chuỗi mạnh
# Đây là password vào trang Admin Studio - admin.html
# -----------------------------------------------------------------------------
ADMIN_TOKEN=<TOKEN_MANH_32_KY_TU_TRO_LEN>

# -----------------------------------------------------------------------------
# Cấu hình demo (chỉ để dev/test)
# Production phải set USE_REAL_DATE=true
# -----------------------------------------------------------------------------
DEBUG_SQL=false
USE_REAL_DATE=true
DEMO_TODAY=2026-05-13

# -----------------------------------------------------------------------------
# CORS - các origin được phép gọi API chatbot
# Liệt kê chính xác URL của các web nhúng chatbot
#
# Ví dụ:
#   - User truy cập trực tiếp: http://192.168.1.50:8080
#   - Nhúng widget vào portal nội bộ: http://portal.benhvien.local
#   - Trang web bệnh viện: http://www.benhvien.local
#
# Tách bằng dấu phẩy, KHÔNG có khoảng trắng giữa các origin
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://192.168.1.50:8080,http://portal.benhvien.local

# -----------------------------------------------------------------------------
# (Optional) MinIO - chỉ điền nếu chạy MinIO trên server khác
# Mặc định nếu MinIO chạy chung server qua docker-compose thì không cần điền,
# tạo connection trong admin với endpoint=127.0.0.1 port=9000
# -----------------------------------------------------------------------------
# MINIO_ENDPOINT=127.0.0.1
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=<DOI_KEY>
# MINIO_SECRET_KEY=<DOI_SECRET>
