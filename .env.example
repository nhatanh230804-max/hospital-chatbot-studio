# =============================================================================
# Hospital Chatbot Studio v2.5 - Environment Configuration
# =============================================================================
# Copy file này thành `.env` rồi sửa các giá trị bên dưới.
# KHÔNG commit file `.env` thật lên git.
#
# Generate password mạnh (32 ký tự):
#   Linux:   openssl rand -base64 32
#   Windows: -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | % {[char]$_})
# =============================================================================

# -----------------------------------------------------------------------------
# Server config
# -----------------------------------------------------------------------------
PORT=8080

# -----------------------------------------------------------------------------
# DB CỦA CHATBOT (lưu FAQ, template, schema metadata, logs)
# -----------------------------------------------------------------------------
# Có 2 cách deploy DB này:
#
# CÁCH A (mặc định - khuyên dùng cho dev/POC):
#   Dùng MySQL trong Docker container `hospital-demo-mysql-v2`
#   → giữ nguyên DB_HOST=127.0.0.1
#
# CÁCH B (cho production bệnh viện có sẵn MySQL native):
#   Dùng MySQL native của bệnh viện
#   → đổi DB_HOST thành IP MySQL server bệnh viện
#   → tạo DB + user trên MySQL native trước (xem HUONG-DAN-IT.md mục 8.3)
#
# Lưu ý: DB_PASSWORD phải KHỚP với MYSQL_PASSWORD trong docker-compose.yml (nếu dùng cách A)
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=hospital_user
DB_PASSWORD=hospital_pass
DB_NAME=hospital_demo

# -----------------------------------------------------------------------------
# AnythingLLM (AI engine - bắt buộc dùng Docker stack riêng)
# -----------------------------------------------------------------------------
# - BASE_URL: nếu Node app cùng host với AnythingLLM Docker → http://localhost:3001
#             nếu AnythingLLM ở server khác → http://<ip>:3001
# - API_KEY: lấy từ AnythingLLM Admin → Settings → Tools → Developer API
# - WORKSPACE_SLUG: tên workspace, phải khớp với workspace đã tạo trên AnythingLLM
# - MODE: "chat" (chỉ chat thuần) hoặc "agent" (có web search) - mặc định "chat"
# -----------------------------------------------------------------------------
ANYTHINGLLM_BASE_URL=http://localhost:3001
ANYTHINGLLM_API_KEY=replace_with_your_api_key
ANYTHINGLLM_WORKSPACE_SLUG=test-chatbot-bv
ANYTHINGLLM_MODE=chat

# -----------------------------------------------------------------------------
# Admin Token (đăng nhập Admin Studio)
# -----------------------------------------------------------------------------
# ĐỔI THÀNH CHUỖI NGẪU NHIÊN 32+ KÝ TỰ trước khi deploy production!
# Đây là password chính để admin truy cập backend, KHÔNG để giá trị mặc định.
# -----------------------------------------------------------------------------
ADMIN_TOKEN=admin123

# -----------------------------------------------------------------------------
# Debug + Demo settings
# -----------------------------------------------------------------------------
# DEBUG_SQL: hiện SQL được sinh trong response (chỉ dùng dev, tắt khi production)
# USE_REAL_DATE: false = dùng DEMO_TODAY làm "hôm nay" (cho demo)
#                true  = dùng ngày thật của server
# DEMO_TODAY: ngày coi là "hôm nay" khi USE_REAL_DATE=false (format YYYY-MM-DD)
# -----------------------------------------------------------------------------
DEBUG_SQL=false
USE_REAL_DATE=false
DEMO_TODAY=2026-05-07

# -----------------------------------------------------------------------------
# CORS - các domain được phép gọi API chatbot
# -----------------------------------------------------------------------------
# Liệt kê tất cả URL nhúng widget hoặc embed iframe, cách nhau bằng dấu phẩy.
# Vd nếu deploy lên server 192.168.1.50:
#   ALLOWED_ORIGINS=http://192.168.1.50:8080,http://portal.benhvien.local
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:8080

# -----------------------------------------------------------------------------
# MinIO default (kho file PDF, biểu mẫu)
# -----------------------------------------------------------------------------
# MinIO chạy trong Docker (xem docker-compose.yml).
# Sau khi `docker compose up -d`:
#   - Vào http://localhost:9001 (MinIO Console)
#   - Login: minioadmin / minioadmin123 (ĐỔI password khi deploy production!)
#   - Tạo bucket (vd "hospital-files")
#   - Vào Admin Studio → Kết nối DB/Storage → tạo MinIO connection
#
# Các biến này là default được pre-fill khi admin tạo MinIO connection lần đầu.
# -----------------------------------------------------------------------------
MINIO_DEFAULT_ENDPOINT=127.0.0.1
MINIO_DEFAULT_PORT=9000
MINIO_DEFAULT_ACCESS_KEY=minioadmin
MINIO_DEFAULT_SECRET_KEY=minioadmin123